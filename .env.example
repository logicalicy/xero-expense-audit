# Xero OAuth 2.0 (Web App — Authorization Code + Refresh Token).
# Get Client ID + Secret from developer.xero.com → your app → Configuration.
XERO_CLIENT_ID=
XERO_CLIENT_SECRET=
# These are filled automatically by: python audit.py setup-auth.
XERO_REFRESH_TOKEN=
XERO_TENANT_ID=

# Anthropic (defaults to Haiku — cheapest, fastest; override only if needed).
ANTHROPIC_API_KEY=
ANTHROPIC_MODEL=claude-haiku-4-5

# Behaviour.
# auto | queue (queue = never auto-correct, always ask).
CORRECTION_MODE=queue
BASE_CURRENCY=GBP

# How many days back to look for bills to audit (default: 30).
AUDIT_LOOKBACK_DAYS=30
